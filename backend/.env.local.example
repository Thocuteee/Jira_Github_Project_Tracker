# LOCAL ONLY (do not commit `.env.local`)
# Copy this file -> `.env.local` then edit values.

# Local URLs (run nginx on your machine via docker compose)
FRONTEND_URL=http://localhost
VITE_API_GATEWAY_URL=http://localhost
# IMPORTANT:
# Frontend code already calls `/api/auth/...` in many places, so this base URL
# must NOT include `/api/auth` (otherwise it becomes `/api/auth/api/auth/...`).
VITE_AUTH_SERVICE_URL=http://localhost
VITE_GROUP_SERVICE_URL=http://localhost/api/groups
VITE_REQUIREMENT_SERVICE_URL=http://localhost/api/requirements
VITE_TASK_SERVICE_URL=http://localhost/api/tasks
VITE_REPORT_SERVICE_URL=http://localhost/api/reports
VITE_NOTIFICATION_SERVICE_URL=http://localhost/api/notifications
VITE_GITHUB_SERVICE_URL=http://localhost/api/github
VITE_JIRA_SERVICE_URL=http://localhost/api/jira
VITE_EXPORT_SERVICE_URL=http://localhost/api/exports

# Local DB (Docker Postgres)
# If you prefer Neon locally, replace these with your Neon URLs/user/pass.
LOCAL_DB_USER=postgres
LOCAL_DB_PASS=postgres

SPRING_DATASOURCE_URL_AUTH=jdbc:postgresql://postgres:5432/auth_db
DB_USER_AUTH=${LOCAL_DB_USER}
DB_PASS_AUTH=${LOCAL_DB_PASS}
SPRING_DATASOURCE_URL_GROUP=jdbc:postgresql://postgres:5432/group_db
DB_USER_GROUP=${LOCAL_DB_USER}
DB_PASS_GROUP=${LOCAL_DB_PASS}

SPRING_DATASOURCE_URL_REQUIREMENT=jdbc:postgresql://postgres:5432/requirement_db
DB_USER_REQUIREMENT=${LOCAL_DB_USER}
DB_PASS_REQUIREMENT=${LOCAL_DB_PASS}

SPRING_DATASOURCE_URL_TASK=jdbc:postgresql://postgres:5432/task_db
DB_USER_TASK=${LOCAL_DB_USER}
DB_PASS_TASK=${LOCAL_DB_PASS}

SPRING_DATASOURCE_URL_REPORT=jdbc:postgresql://postgres:5432/report_db
DB_USER_REPORT=${LOCAL_DB_USER}
DB_PASS_REPORT=${LOCAL_DB_PASS}

SPRING_DATASOURCE_URL_NOTIFICATION=jdbc:postgresql://postgres:5432/notification_db
DB_USER_NOTIFICATION=${LOCAL_DB_USER}
DB_PASS_NOTIFICATION=${LOCAL_DB_PASS}

SPRING_DATASOURCE_URL_GITHUB=jdbc:postgresql://postgres:5432/github_db
DB_USER_GITHUB=${LOCAL_DB_USER}
DB_PASS_GITHUB=${LOCAL_DB_PASS}

SPRING_DATASOURCE_URL_JIRA=jdbc:postgresql://postgres:5432/jira_db
DB_USER_JIRA=${LOCAL_DB_USER}
DB_PASS_JIRA=${LOCAL_DB_PASS}

SPRING_DATASOURCE_URL_EXPORT=jdbc:postgresql://postgres:5432/export_db
DB_USER_EXPORT=${LOCAL_DB_USER}
DB_PASS_EXPORT=${LOCAL_DB_PASS}

# Redis (docker compose provides redis by default)
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# JWT
JWT_SECRET=dev-secret-change-me
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# OAuth (optional for local)
# Keep these non-empty to avoid Spring OAuth client bootstrap failure.
# Replace with real values only if you want to test OAuth locally.
GOOGLE_CLIENT_ID=local-google-client-id
GOOGLE_CLIENT_SECRET=local-google-client-secret
GITHUB_CLIENT_ID=local-github-client-id
GITHUB_CLIENT_SECRET=local-github-client-secret

# Firebase Admin (FCM) — notification-service
# Base64 (no newlines) of the full service account JSON file. Preferred over mounting a JSON file.
# FIREBASE_CREDENTIALS_BASE64=
# Optional file path inside the container if Base64 is not set:
# FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# Optional integrations
JIRA_API_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=

CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_PUBLIC_DOMAIN=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET_NAME=

