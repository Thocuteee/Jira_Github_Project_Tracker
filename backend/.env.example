# ==========================================
# FILE MẪU CẤU HÌNH (ENV EXAMPLE)
# Team copy file này thành file .env và điền giá trị cá nhân
# ==========================================
#
# Gợi ý:
# - VPS/Production: tạo `backend/.env` trên VPS (KHÔNG commit)
# - Local: copy `backend/.env.local.example` -> `backend/.env.local` (KHÔNG commit)

# VPS configuration
DOMAIN=swp391.uth.today

# Databases (Điền URL của team hoặc local)
SPRING_DATASOURCE_URL_AUTH=
DB_USER_AUTH=
DB_PASS_AUTH=

SPRING_DATASOURCE_URL_GITHUB=
DB_USER_GITHUB=
DB_PASS_GITHUB=

# Thêm tất cả các database khác tương tự...

# JWT Secrets
JWT_SECRET=Hãy_điền_chuỗi_ngẫu_nhiên_ở_đây
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# OAuth2 (Lấy Client ID/Secret từ Google/Github Console)
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret
GITHUB_CLIENT_ID=your_github_id
GITHUB_CLIENT_SECRET=your_github_secret

# Storage Cloudflare R2
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_PUBLIC_DOMAIN=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET_NAME=

# RabbitMQ
RABBIT_USER=admin
RABBIT_PASS=123

# Frontend URLs (Tự động thay đổi theo DOMAIN trong file CI/CD)
VITE_API_GATEWAY_URL=https://${DOMAIN}
VITE_AUTH_SERVICE_URL=https://${DOMAIN}/api/auth
# ... và các service khác
